# @BotFather dan olingan token
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# HRMM backend URL (https:// bilan yozing)
HRMM_API_BASE_URL=https://your-hrmm-backend.example.com

# Sessiya shifrlash kaliti (min 32 belgi, generatsiya qiling:
#   python -c "import secrets; print(secrets.token_urlsafe(32))")
SESSION_ENCRYPTION_KEY=change-me-to-a-random-32-char-key

# Sessiya fayli (Railway da volume yoki /tmp)
SESSIONS_FILE=/tmp/hrmm_bot_sessions.json

# Railway healthcheck uchun (ixtiyoriy)
PORT=8080
