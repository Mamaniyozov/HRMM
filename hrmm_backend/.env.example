# =============================================================================
# HRMM Backend — Environment Variables Template
# =============================================================================
# Usul:
#   1. Bu fayldan nusxa oling:  cp .env.example .env
#   2. Qiymatlarni o'zgartiring (SECRET_KEY, DB parollari, va h.k.)
#   3. .env faylini HECH QACHON git'ga commit qilmang (.gitignore'da)
# =============================================================================

# ---------------------------------------------------------------------------
# 1. DJANGO CORE
# ---------------------------------------------------------------------------
# Minimal 50 belgi, tasodifiy string. Generatsiya:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changeme-to-a-long-random-string-at-least-50-chars-long-xyz123

# Debug rejim. PRODUCTION'DA HAR DOIM False!
DEBUG=False

# Vergul bilan ajratilgan domenlar. Misol: hrmm.example.com,api.hrmm.example.com
ALLOWED_HOSTS=hrmm.example.com

# ---------------------------------------------------------------------------
# 2. DATABASE (PostgreSQL)
# ---------------------------------------------------------------------------
# Variant A: to'liq DATABASE_URL (tavsiya etiladi, Railway/Render uchun qulay)
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://hrmm_user:change_me@localhost:5432/hrmm_db

# Variant B: alohida o'zgaruvchilar (DATABASE_URL bo'lmasa ishlatiladi)
# DB_NAME=hrmm_db
# DB_USER=hrmm_user
# DB_PASSWORD=change_me
# DB_HOST=localhost
# DB_PORT=5432

# PostgreSQL ulanish timeouti (soniya)
PG_CONNECT_TIMEOUT=10

# ---------------------------------------------------------------------------
# 3. EMAIL (SMTP)
# ---------------------------------------------------------------------------
# Lokal development uchun console backend ishlatish:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=change_me_app_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# ---------------------------------------------------------------------------
# 4. CORS / CSRF
# ---------------------------------------------------------------------------
# Frontend domenlari (vergul bilan). Misol: https://hrmm.example.com,https://app.hrmm.example.com
CORS_ALLOWED_ORIGINS=https://hrmm.example.com

# CSRF ishonchli originlar (CORS_ALLOWED_ORIGINS bilan bir xil bo'lishi mumkin)
CSRF_TRUSTED_ORIGINS=https://hrmm.example.com

# ---------------------------------------------------------------------------
# 5. SECURITY (production.py uchun)
# ---------------------------------------------------------------------------
# HTTPS redirect (production'da True tavsiya etiladi)
SECURE_SSL_REDIRECT=True
# HSTS davomiyligi (soniya, default 1 yil)
SECURE_HSTS_SECONDS=31536000
# Sessiya muddati (soniya, default 8 soat)
SESSION_COOKIE_AGE=28800

# ---------------------------------------------------------------------------
# 6. FILE UPLOAD LIMITLARI
# ---------------------------------------------------------------------------
# Fayl xotirada saqlanadigan maksimal hajm (bayt, default 2 MB)
FILE_UPLOAD_MAX_MEMORY_SIZE=2097152
# Request body maksimal hajmi (bayt, default 20 MB)
DATA_UPLOAD_MAX_MEMORY_SIZE=20971520
# Bir request'dagi maydonlar soni (default 1000)
DATA_UPLOAD_MAX_NUMBER_FIELDS=1000

# ---------------------------------------------------------------------------
# 7. 2FA / TOTP
# ---------------------------------------------------------------------------
# TOTP issuer nomi (Google Authenticator'da ko'rinadi)
TOTP_ISSUER_NAME=HRMM Control Center
# totp_secret maydonini shifrlash kaliti (Fernet, min 32 bayt)
FIELD_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# 8. TELEGRAM (alohidalik uchun, ops uchun)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Telegram bot session faylini shifrlash kaliti (Fernet, min 32 bayt)
SESSION_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# 9. ARCHIVE
# ---------------------------------------------------------------------------
# Arxivlashdan keyin necha kunda o'chirish (default 7)
ARCHIVE_RETENTION_DAYS=7
# Arxiv modellari (vergul bilan, bo'sh = default)
# ARCHIVE_MODELS=reports.Report,notifications.Notification

# ---------------------------------------------------------------------------
# 10. LOGGING
# ---------------------------------------------------------------------------
# Log katalogi (default: <backend>/logs)
# HRMM_LOGS_DIR=/var/log/hrmm
