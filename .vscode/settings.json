{
    "python.defaultInterpreterPath": "${workspaceFolder}\\hrmm_backend\\venv\\Scripts\\python.exe",
    "python.analysis.extraPaths": [
        "${workspaceFolder}\\hrmm_backend"
    ],
    "python.analysis.exclude": [
        "**/venv/**",
        "**/__pycache__/**"
    ],
    "python.analysis.typeCheckingMode": "basic",
    "python.testing.cwd": "${workspaceFolder}\\hrmm_backend",
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true
}
